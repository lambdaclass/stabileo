# Required
DEDALIANO_API_KEY=your-api-key-here

# Provider selection: claude, openai, deepseek, mistral, kimi, gemini
AI_PROVIDER=claude

# Provider API keys (only the one matching AI_PROVIDER is required)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here
# DEEPSEEK_API_KEY=sk-your-key-here
# MISTRAL_API_KEY=your-key-here
# KIMI_API_KEY=your-key-here
# GEMINI_API_KEY=your-key-here

# Optional model override (defaults per provider: claude-sonnet-4-20250514, gpt-4o,
# deepseek-chat, mistral-large-latest, moonshot-v1-128k, gemini-2.5-flash)
# AI_MODEL=claude-sonnet-4-20250514

# Optional
# HOST=0.0.0.0
# PORT=3001
# ALLOWED_ORIGINS=https://stabileo.com,https://dedaliano.com
# LOG_FORMAT=pretty
